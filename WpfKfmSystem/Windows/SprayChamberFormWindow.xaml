<local:SprayChamberFormWindowBase x:Class="WpfPorkProcessSystem.Windows.SprayChamberFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfPorkProcessSystem.Windows.Base"
        mc:Ignorable="d"
        Title="Form - Spray Chamber" 
        Height="450" 
        Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Grid.Row="0" 
                   x:Name="TxtTitle"
                   Text="New Spray Chamber" 
                   FontSize="20" 
                   FontWeight="Bold" 
                   Margin="0,0,0,20"/>

        <!-- ID (only view in edit mode) -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10" x:Name="PnlId" Visibility="Collapsed">
            <TextBlock Text="ID:" Width="120" VerticalAlignment="Center" FontWeight="Bold"/>
            <TextBlock x:Name="TxtIdDisplay" VerticalAlignment="Center" FontSize="14"/>
        </StackPanel>

        <!-- Name Field -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Grid.Column="0" Text="Name:*" VerticalAlignment="Center" FontWeight="Bold"/>
            <TextBox Grid.Column="1" 
                     x:Name="TxtName" 
                     VerticalAlignment="Center"
                     Padding="5"
                     FontSize="14"/>
        </Grid>

        <!-- Description Field -->
        <Grid Grid.Row="3" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Grid.Column="0" Text="Description:" VerticalAlignment="Top" FontWeight="Bold" Margin="0,5,0,0"/>
            <TextBox Grid.Column="1" 
                     x:Name="TxtDescription" 
                     Padding="5"
                     FontSize="14"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     Height="60"
                     VerticalScrollBarVisibility="Auto"/>
        </Grid>

        <!-- Capacity Field -->
        <Grid Grid.Row="4" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Grid.Column="0" Text="Capacity:*" VerticalAlignment="Center" FontWeight="Bold"/>
            <TextBox Grid.Column="1" 
                     x:Name="TxtCapacity" 
                     VerticalAlignment="Center"
                     Padding="5"
                     FontSize="14"
                     TextAlignment="Right"/>
        </Grid>

        <!-- Stock Field -->
        <Grid Grid.Row="5" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Grid.Column="0" Text="Stock:" VerticalAlignment="Center" FontWeight="Bold"/>
            <TextBox Grid.Column="1" 
                     x:Name="TxtStock" 
                     VerticalAlignment="Center"
                     Padding="5"
                     FontSize="14"
                     TextAlignment="Right"
                     Text="0"/>
        </Grid>

        <!-- Validation Message -->
        <TextBlock Grid.Row="7" 
                   x:Name="TxtValidation" 
                   Foreground="Red" 
                   TextWrapping="Wrap"
                   Visibility="Collapsed"
                   Margin="0,5,0,10"/>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="BtnSave" 
                    Content="Save" 
                    Width="100" 
                    Height="35"
                    Margin="0,0,10,0"
                    Click="BtnSave_Click"
                    IsDefault="True">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#4CAF50"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#45a049"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            
            <Button x:Name="BtnCancel" 
                    Content="Cancel" 
                    Width="100" 
                    Height="35"
                    Click="BtnCancel_Click"
                    IsCancel="True">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#f44336"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#da190b"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</local:SprayChamberFormWindowBase>
