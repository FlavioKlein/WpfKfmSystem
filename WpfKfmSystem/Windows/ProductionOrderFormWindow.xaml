<local:ProductionOrderFormWindowBase x:Class="WpfPorkProcessSystem.Windows.ProductionOrderFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfPorkProcessSystem.Windows.Base"
        mc:Ignorable="d"
        Title="Production Order Form" 
        Height="850" 
        Width="950"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Grid.Row="0" 
                   x:Name="TxtTitle"
                   Text="New Production Order" 
                   FontSize="20" 
                   FontWeight="Bold" 
                   Margin="0,0,0,20"/>

		<!-- Campos do Cabeçalho -->
		<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="300">
			<StackPanel>
				<!-- ID (apenas visualização em modo edição) -->
				<StackPanel Orientation="Horizontal" Margin="0,0,0,15" x:Name="PnlId" Visibility="Collapsed">
					<TextBlock Text="ID:" Width="80" VerticalAlignment="Center" FontWeight="Bold"/>
					<TextBlock x:Name="TxtIdDisplay" VerticalAlignment="Center" FontSize="14"/>
				</StackPanel>

				<!-- Type/Status -->
				<Grid Margin="0,0,0,15">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="10"/>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="10"/>
						<ColumnDefinition Width="*"/>
					</Grid.ColumnDefinitions>

					<StackPanel Grid.Column="0">
						<TextBlock Text="Type:*" FontWeight="Bold" Margin="0,0,0,5" TextAlignment="Left"/>
						<ComboBox x:Name="CmbType" Padding="5" FontSize="14" SelectionChanged="CmbType_SelectionChanged"/>
					</StackPanel>

					<StackPanel Grid.Column="2">
						<TextBlock Text="Status:*" FontWeight="Bold" Margin="0,0,0,5" TextAlignment="Left"/>
						<ComboBox x:Name="CmbStatus" Padding="5" FontSize="14" SelectionChanged="CmbStatus_SelectionChanged"/>
					</StackPanel>
					
					<!-- Entrance Order Number (Only for Exit orders) -->
					<StackPanel Grid.Column="5" Margin="0,0,0,15" x:Name="PnlEntranceOrderNumber" Visibility="Collapsed">
						<TextBlock Text="Entrance Order #:" FontWeight="Bold" Margin="0,0,0,5" TextAlignment="Left"/>
						<ComboBox x:Name="CmbEntranceOrder" Padding="5" FontSize="14" DisplayMemberPath="Id" SelectedValuePath="Id"/>
					</StackPanel>
					
				</Grid>							

				<!-- Simulator Configuration -->
				<TextBlock Text="Simulator Configuration" FontSize="14" FontWeight="Bold" Margin="0,5,0,10"/>

				<!-- Lower/Upper Limit Weight -->
				<Grid Margin="0,0,0,15">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="10"/>
						<ColumnDefinition Width="*"/>
					</Grid.ColumnDefinitions>

					<StackPanel Grid.Column="0">
						<TextBlock Text="Lower Limit Weight:" FontWeight="Bold" Margin="0,0,0,5" TextAlignment="Left"/>
						<TextBox x:Name="TxtLowerLimitWeight" Padding="5" FontSize="14"/>
					</StackPanel>

					<StackPanel Grid.Column="2">
						<TextBlock Text="Upper Limit Weight:" FontWeight="Bold" Margin="0,0,0,5" TextAlignment="Left"/>
						<TextBox x:Name="TxtUpperLimitWeight" Padding="5" FontSize="14"/>
					</StackPanel>
				</Grid>

				<!-- Delay/Generate Quantity -->
				<Grid Margin="0,0,0,15">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="10"/>
						<ColumnDefinition Width="*"/>
					</Grid.ColumnDefinitions>

					<StackPanel Grid.Column="0">
						<TextBlock Text="Delay (seconds):" FontWeight="Bold" Margin="0,0,0,5" TextAlignment="Left"/>
						<TextBox x:Name="TxtDelayGenerator" Padding="5" FontSize="14"/>
					</StackPanel>

					<StackPanel Grid.Column="2">
						<TextBlock Text="Generate Quantity:" FontWeight="Bold" Margin="0,0,0,5" TextAlignment="Left"/>
						<TextBox x:Name="TxtGenerateQuantity" Padding="5" FontSize="14"/>
					</StackPanel>
				</Grid>

				<!-- Production Order Configuration -->
				<TextBlock Text="Production Order Configuration" FontSize="14" FontWeight="Bold" Margin="0,5,0,10"/>				

				<!-- Product/Weighing Scale ID -->
				<Grid Margin="0,0,0,15">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="10"/>
						<ColumnDefinition Width="*"/>
					</Grid.ColumnDefinitions>

					<StackPanel Grid.Column="0">
						<TextBlock Text="Product:*" FontWeight="Bold" Margin="0,0,0,5" TextAlignment="Left"/>
						<ComboBox x:Name="CmbProduct" Padding="5" FontSize="14" DisplayMemberPath="Name" SelectedValuePath="Id"/>
					</StackPanel>

					<StackPanel Grid.Column="2">
						<TextBlock Text="Weighing Scale ID:*" FontWeight="Bold" Margin="0,0,0,5" TextAlignment="Left"/>
						<ComboBox x:Name="CmbWeighingScale" Padding="5" FontSize="14" DisplayMemberPath="Name" SelectedValuePath="Id"/>
					</StackPanel>
				</Grid>

				<!-- Execution/Expiration/Facturing Dates -->
				<Grid Margin="0,0,0,15">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="10"/>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="10"/>
						<ColumnDefinition Width="*"/>
					</Grid.ColumnDefinitions>

					<StackPanel Grid.Column="0">
						<TextBlock Text="Execution Date:*" FontWeight="Bold" Margin="0,0,0,5" TextAlignment="Left"/>
						<DatePicker x:Name="DtpExecutionDate" Padding="5" FontSize="14"/>
					</StackPanel>

					<StackPanel Grid.Column="2">
						<TextBlock Text="Expiration Date:*" FontWeight="Bold" Margin="0,0,0,5" TextAlignment="Left"/>
						<DatePicker x:Name="DtpExpirationDate" Padding="5" FontSize="14"/>
					</StackPanel>

					<StackPanel Grid.Column="4">
						<TextBlock Text="Facturing Date:*" FontWeight="Bold" Margin="0,0,0,5" TextAlignment="Left"/>
						<DatePicker x:Name="DtpFacturingDate" Padding="5" FontSize="14"/>
					</StackPanel>
				</Grid>

				<!-- Campos específicos para Entrance Type -->
				<StackPanel x:Name="PnlEntranceFields">
					<!-- Shift/Batch/Hammer -->
					<Grid Margin="0,0,0,15">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="10"/>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="10"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>

						<StackPanel Grid.Column="0">
							<TextBlock Text="Shift:" FontWeight="Bold" Margin="0,0,0,5" TextAlignment="Left"/>
							<TextBox x:Name="TxtShift" Padding="5" FontSize="14"/>
						</StackPanel>

						<StackPanel Grid.Column="2">
							<TextBlock Text="Batch:" FontWeight="Bold" Margin="0,0,0,5" TextAlignment="Left"/>
							<TextBox x:Name="TxtBatch" Padding="5" FontSize="14"/>
						</StackPanel>

						<StackPanel Grid.Column="4">
							<TextBlock Text="Hammer:" FontWeight="Bold" Margin="0,0,0,5" TextAlignment="Left"/>
							<TextBox x:Name="TxtHammer" Padding="5" FontSize="14"/>
						</StackPanel>
					</Grid>

					<!-- Description (Full Width) -->
					<StackPanel Margin="0,0,0,15">
						<TextBlock Text="Description:" FontWeight="Bold" Margin="0,0,0,5" TextAlignment="Left"/>
						<TextBox x:Name="TxtDescription" Padding="5" FontSize="14" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>
					</StackPanel>
				</StackPanel>

				<!-- Quantity Carcasses/Total Weighing -->
				<Grid Margin="0,0,0,15">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="10"/>
						<ColumnDefinition Width="*"/>
					</Grid.ColumnDefinitions>

					<StackPanel Grid.Column="0">
						<TextBlock Text="Qty Carcasses:" FontWeight="Bold" Margin="0,0,0,5" TextAlignment="Left"/>
						<TextBox x:Name="TxtQuantityCarcasses" IsEnabled="false" Padding="5" FontSize="14"/>
					</StackPanel>

					<StackPanel Grid.Column="2">
						<TextBlock Text="Total Weighing:" FontWeight="Bold" Margin="0,0,0,5" TextAlignment="Left"/>
						<TextBox x:Name="TxtTotalWeighing" IsEnabled="false" Padding="5" FontSize="14"/>
					</StackPanel>
				</Grid>
			</StackPanel>
		</ScrollViewer>

        <!-- Seção de Itens (ProductionOrderItemModel) -->
        <Grid Grid.Row="2" Margin="0,20,0,0" x:Name="PnlItems" >
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Título dos Itens -->
            <TextBlock Grid.Row="0" x:Name="TxtItemsTitle" Text="Order Items (Chamber Distribution/Sequence)" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

            <!-- Botões de gerenciamento de itens -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                <Button x:Name="BtnAddItem" Content="Add Item" Width="100" Height="30" Margin="0,0,10,0" Click="BtnAddItem_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#2196F3"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#0b7dda"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="BtnEditItem" Content="Edit Item" Width="100" Height="30" Margin="0,0,10,0" Click="BtnEditItem_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#FF9800"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#e68900"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="BtnRemoveItem" Content="Remove Item" Width="100" Height="30" Click="BtnRemoveItem_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#f44336"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#da190b"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <!-- DataGrid dos Itens -->
            <Border Grid.Row="2" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="3">
                <DataGrid x:Name="DgItems" 
                          AutoGenerateColumns="False" 
                          IsReadOnly="True"
                          SelectionMode="Single"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          AlternatingRowBackground="#F5F5F5">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Sequential" Binding="{Binding Sequential}" Width="100"/>
                        <DataGridTextColumn Header="Spray Chamber ID" Binding="{Binding SprayChamberId}" Width="140"/>
                        <DataGridTextColumn Header="Chamber Capacity" Binding="{Binding SprayChamberCapacity}" Width="140"/>
                        <DataGridTextColumn Header="Initial Stock" Binding="{Binding SprayChamberInitialStock}" Width="120"/>
                        <DataGridTextColumn Header="Current Stock" Binding="{Binding SprayChamberStock}" Width="110"/>
                        <DataGridTextColumn Header="Accept Classifications" Binding="{Binding AcceptClassifications}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- Área de validação e botões -->
        <StackPanel Grid.Row="3">
            <!-- Mensagem de Validação -->
            <TextBlock x:Name="TxtValidation" 
                       Foreground="Red" 
                       TextWrapping="Wrap"
                       Visibility="Collapsed"
                       Margin="0,10,0,10"/>

            <!-- Simulator Controls -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <CheckBox x:Name="ChkAutoRefresh" 
                          Content="Auto-refresh (updates every 2s when executing)" 
                          VerticalAlignment="Center" 
                          Margin="0,0,20,0"
                          FontSize="14"/>
                <Button x:Name="BtnClearSimulation" 
                        Content="Clear Simulation" 
                        Width="150" 
                        Height="30"
                        Click="BtnClearSimulation_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#9C27B0"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#7B1FA2"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <!-- Botões de Ação -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button x:Name="BtnSave" 
                        Content="Save" 
                        Width="100" 
                        Height="35"
                        Margin="0,0,10,0"
                        Click="BtnSave_Click"
                        IsDefault="True">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#4CAF50"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#45a049"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button x:Name="BtnCancel" 
                        Content="Cancel" 
                        Width="100" 
                        Height="35"
                        Click="BtnCancel_Click"
                        IsCancel="True">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#f44336"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#da190b"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </StackPanel>
    </Grid>
</local:ProductionOrderFormWindowBase>
