<Window x:Class="WpfPorkProcessSystem.Windows.ProductionOrderItemFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Production Order Item Form" 
        Height="450" 
        Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Grid.Row="0" 
                   x:Name="TxtTitle"
                   Text="New Production Order Item" 
                   FontSize="18" 
                   FontWeight="Bold" 
                   Margin="0,0,0,20"/>

        <!-- Campos -->
        <StackPanel Grid.Row="1">
            <!-- Spray Chamber -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Spray Chamber:*" VerticalAlignment="Center" FontWeight="Bold"/>
                <ComboBox Grid.Column="1" x:Name="CmbSprayChamber" VerticalAlignment="Center" Padding="5" FontSize="14" 
                          DisplayMemberPath="Name" SelectedValuePath="Id" SelectionChanged="CmbSprayChamber_SelectionChanged"/>
            </Grid>

            <!-- Chamber Capacity (Read-only) -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Chamber Capacity:" VerticalAlignment="Center" FontWeight="Bold"/>
                <TextBox Grid.Column="1" x:Name="TxtChamberCapacity" VerticalAlignment="Center" Padding="5" FontSize="14" IsReadOnly="True" Background="#F0F0F0"/>
            </Grid>

            <!-- Chamber Stock (Read-only) -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Chamber Stock:" VerticalAlignment="Center" FontWeight="Bold"/>
                <TextBox Grid.Column="1" x:Name="TxtChamberStock" VerticalAlignment="Center" Padding="5" FontSize="14" IsReadOnly="True" Background="#F0F0F0"/>
            </Grid>
        </StackPanel>

        <!-- Accept Classifications Section -->
        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Accept Classifications:*" FontWeight="Bold" Margin="0,0,0,5"/>
            
            <Border Grid.Row="1" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="3" MaxHeight="120">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="IcClassifications">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Name}" Tag="{Binding Id}" Margin="5" FontSize="12"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Mensagem de Validação -->
        <TextBlock Grid.Row="3" 
                   x:Name="TxtValidation" 
                   Foreground="Red" 
                   TextWrapping="Wrap"
                   Visibility="Collapsed"
                   Margin="0,10,0,10"
                   VerticalAlignment="Top"/>

        <!-- Botões de Ação -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="BtnSave" 
                    Content="Save" 
                    Width="100" 
                    Height="35"
                    Margin="0,0,10,0"
                    Click="BtnSave_Click"
                    IsDefault="True">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#4CAF50"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#45a049"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button x:Name="BtnCancel" 
                    Content="Cancel" 
                    Width="100" 
                    Height="35"
                    Click="BtnCancel_Click"
                    IsCancel="True">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#f44336"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#da190b"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>
