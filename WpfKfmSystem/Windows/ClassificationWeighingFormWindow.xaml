<local:ClassificationWeighingFormWindowBase x:Class="WpfPorkProcessSystem.Windows.ClassificationWeighingFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfPorkProcessSystem.Windows.Base"
        mc:Ignorable="d"
        Title="Cadastro de Classificação de Pesagem" 
        Height="450" 
        Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" 
                   x:Name="TxtTitle"
                   Text="New Classification Weighing" 
                   FontSize="20" 
                   FontWeight="Bold" 
                   Margin="0,0,0,20"/>

        <!-- ID (only view in edit mode) -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10" x:Name="PnlId" Visibility="Collapsed">
            <TextBlock Text="ID:" Width="120" VerticalAlignment="Center" FontWeight="Bold"/>
            <TextBlock x:Name="TxtIdDisplay" VerticalAlignment="Center" FontSize="14"/>
        </StackPanel>

        <!-- Name and Product Fields -->
        <Grid Grid.Row="2" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Name:*" FontWeight="Bold" Margin="0,0,0,5" TextAlignment="Left"/>
                <TextBox x:Name="TxtName" Padding="5" FontSize="14"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Product:*" FontWeight="Bold" Margin="0,0,0,5" TextAlignment="Left"/>
                <ComboBox x:Name="CmbProduct" Padding="5" FontSize="14" DisplayMemberPath="Name" SelectedValuePath="Id" SelectionChanged="CmbProduct_SelectionChanged"/>
            </StackPanel>
        </Grid>

        <!-- Lower Limit and Upper Limit Fields -->
        <Grid Grid.Row="3" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Lower Limit:*" FontWeight="Bold" Margin="0,0,0,5" TextAlignment="Left"/>
                <TextBox x:Name="TxtLowerLimit" Padding="5" FontSize="14" TextAlignment="Right"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Upper Limit:*" FontWeight="Bold" Margin="0,0,0,5" TextAlignment="Left"/>
                <TextBox x:Name="TxtUpperLimit" Padding="5" FontSize="14" TextAlignment="Right"/>
            </StackPanel>
        </Grid>

        <!-- Validation Message -->
        <TextBlock Grid.Row="4"
                   x:Name="TxtValidation" 
                   Foreground="Red" 
                   TextWrapping="Wrap"
                   Visibility="Collapsed"
                   Margin="0,5,0,10"/>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="BtnSave" 
                    Content="Save" 
                    Width="100" 
                    Height="35"
                    Margin="0,0,10,0"
                    Click="BtnSave_Click"
                    IsDefault="True">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#4CAF50"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#45a049"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            
            <Button x:Name="BtnCancel" 
                    Content="Cancel" 
                    Width="100" 
                    Height="35"
                    Click="BtnCancel_Click"
                    IsCancel="True">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#f44336"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#da190b"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</local:ClassificationWeighingFormWindowBase>
