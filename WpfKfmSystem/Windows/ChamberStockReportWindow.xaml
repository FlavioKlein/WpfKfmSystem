<Window x:Class="WpfPorkProcessSystem.Windows.ChamberStockReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="15">
            <TextBlock Text="Chamber Stock Report" 
                       FontSize="20" 
                       FontWeight="Bold" 
                       Foreground="White"/>
        </Border>

        <!-- Filter Section -->
        <Border Grid.Row="1" Background="#ECF0F1" Padding="15" Margin="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                           Text="Spray Chamber:" 
                           VerticalAlignment="Center" 
                           Margin="0,0,10,0"
                           FontWeight="SemiBold"/>
                
                <ComboBox Grid.Column="1" 
                          x:Name="CmbSprayChamber"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"
                          VerticalAlignment="Center"/>

                <Button Grid.Column="2" 
                        x:Name="BtnLoadReport"
                        Content="Load Report" 
                        Click="BtnLoadReport_Click"
                        Margin="15,0,0,0"
                        Padding="20,8"
                        Background="#3498db"
                        Foreground="White"
                        FontWeight="SemiBold"
                        BorderBrush="#2980b9"
                        Cursor="Hand"/>

                <TextBlock Grid.Column="3" 
                           x:Name="TxtSummary"
                           VerticalAlignment="Center" 
                           HorizontalAlignment="Right"
                           Margin="15,0,0,0"
                           FontWeight="SemiBold"
                           Foreground="#2C3E50"/>
            </Grid>
        </Border>

        <!-- DataGrid -->
        <Border Grid.Row="2" Margin="10" BorderBrush="#BDC3C7" BorderThickness="1">
            <DataGrid x:Name="DgStockItems" 
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      CanUserSortColumns="True"
                      CanUserResizeColumns="True"
                      CanUserReorderColumns="False"
                      AlternatingRowBackground="#F8F9FA"
                      RowHeight="30">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Note ID" Binding="{Binding Id}" Width="80"/>
                    <DataGridTextColumn Header="Order ID" Binding="{Binding ProductionOrderId}" Width="80"/>
                    <DataGridTextColumn Header="Product" Binding="{Binding Product.Name}" Width="150"/>
                    <DataGridTextColumn Header="Classification" Binding="{Binding ClassificationName}" Width="150"/>
                    <DataGridTextColumn Header="Weight (kg)" Binding="{Binding Weight}" Width="100"/>
                    <DataGridTextColumn Header="Execution Date" Binding="{Binding ExecutionDate, StringFormat='{}{0:dd/MM/yyyy}'}" Width="120"/>
                    <DataGridTextColumn Header="Expiration Date" Binding="{Binding ExpirationDate, StringFormat='{}{0:dd/MM/yyyy}'}" Width="120"/>
                    <DataGridTextColumn Header="Shift" Binding="{Binding Shift}" Width="80"/>
                    <DataGridTextColumn Header="Batch" Binding="{Binding Batch}" Width="100"/>
                    <DataGridTextColumn Header="Hammer" Binding="{Binding Hammer}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Close Button -->
        <Border Grid.Row="3" Background="#ECF0F1" Padding="15">
            <Button x:Name="BtnClose" 
                    Content="Close" 
                    Click="BtnClose_Click"
                    HorizontalAlignment="Right"
                    Padding="30,8"
                    Background="#95a5a6"
                    Foreground="White"
                    FontWeight="SemiBold"
                    BorderBrush="#7f8c8d"
                    Cursor="Hand"/>
        </Border>
    </Grid>
</Window>
